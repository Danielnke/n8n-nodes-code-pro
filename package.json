{
  "name": "n8n-nodes-code-pro",
  "version": "0.3.1",
  "description": "Code Pro — JavaScript Code node for n8n with stock-compatible execution and 70+ built-in automation libraries (data, image, video tooling)",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "javascript",
    "code",
    "code-pro",
    "automation",
    "libraries"
  ],
  "license": "MIT",
  "author": {
    "name": "Danielnke"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Danielnke/n8n-nodes-code-pro.git"
  },
  "homepage": "https://github.com/Danielnke/n8n-nodes-code-pro#readme",
  "bugs": {
    "url": "https://github.com/Danielnke/n8n-nodes-code-pro/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/nodes/CodePro/CodePro.node.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const path=require('path');const src='nodes/CodePro/codepro.png';const dest='dist/nodes/CodePro/codepro.png';fs.mkdirSync(path.dirname(dest),{recursive:true});if(fs.existsSync(src))fs.copyFileSync(src,dest); try{fs.unlinkSync('dist/nodes/CodePro/codepro.svg')}catch(e){}\"",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "smoke:libs": "node scripts/smoke-libs.js",
    "test:libs": "node scripts/functional-lib-test.js",
    "test:golden": "node scripts/golden-port.js",
    "verify:n8n-sim": "node scripts/verify-n8n-sim.js",
    "repro:sitemap": "node scripts/repro-sitemap.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/CodePro/CodePro.node.js"
    ]
  },
